=== get_sign(x) sample tests ===
  path=[(0, True)]  outcome='negative'  test={'x': -1000}
  path=[(0, False), (1, True)]  outcome='zero'  test={'x': 0}
  path=[(0, False), (1, False)]  outcome='positive'  test={'x': 1}

=== classify_triangle(a,b,c) sample tests ===
  path=[(0, True)]  outcome='invalid'  test={'a': 0, 'b': 0, 'c': 0}
  path=[(0, False), (1, True)]  outcome='invalid'  test={'a': 2, 'b': 1, 'c': 1}
  path=[(0, False), (1, False), (2, True)]  outcome='equilateral'  test={'a': 1, 'b': 1, 'c': 1}
  path=[(0, False), (1, False), (2, False), (3, True)]  outcome='isosceles'  test={'a': 2, 'b': 2, 'c': 1}
  path=[(0, False), (1, False), (2, False), (3, False)]  outcome='scalene'  test={'a': 2, 'b': 4, 'c': 3}

